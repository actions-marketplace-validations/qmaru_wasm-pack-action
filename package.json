{
  "name": "wasm-pack-action",
  "version": "0.5.3",
  "private": true,
  "description": "wasm-pack action to install wasm-pack by downloading the executable",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "oxlint src/*.ts",
    "pack": "ncc build ./src/main.ts -o dist",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint & npm run pack && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmaru/wasm-pack-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup",
    "wasm-pack"
  ],
  "author": "Jet Li",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^2.0.2",
    "@actions/io": "^2.0.0",
    "@actions/tool-cache": "^3.0.0",
    "typed-rest-client": "^2.2.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.9",
    "@vercel/ncc": "^0.38.4",
    "jest": "^30.2.0",
    "jest-circus": "^30.2.0",
    "js-yaml": "^4.1.1",
    "oxlint": "^1.39.0",
    "prettier": "^3.8.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}